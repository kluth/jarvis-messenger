module SubstrateConfig
complexity O(1)
{
    // Global Energy Budget for the Messenger Substrate
    budget { power: 100000_nj }

    func configure_runtime() {
        target "riscv64-jur";
        target "npu-universal";
        
        feature "wait-free-scheduler";
        feature "rcu-allocator";
        feature "omni-crypto-accel";
    }
}
